// =============================================================
// Betting Exchange + Casino — PostgreSQL schema (Prisma)
// Money columns use Decimal(20,4) — never Float — to preserve
// rupee/cent precision under arithmetic and aggregation.
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------
// Identity & agent hierarchy
// -------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPER_MASTER
  MASTER
  AGENT
  BOOKIE
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  CLOSED
}

model User {
  id              String      @id @default(cuid())
  username        String      @unique
  email           String?     @unique
  phone           String?     @unique
  passwordHash    String
  role            UserRole    @default(USER)
  status          UserStatus  @default(ACTIVE)

  // Agent hierarchy: every non-super-admin has a parent up the tree.
  parentId        String?
  parent          User?       @relation("UserHierarchy", fields: [parentId], references: [id])
  children        User[]      @relation("UserHierarchy")

  // Partnership the parent retains from this user's net P&L (basis points: 1000 = 10%).
  partnershipBps  Int         @default(0)
  // Credit reference shown in agent dashboards (does not affect wallet balance).
  creditReference Decimal     @default(0) @db.Decimal(20, 4)
  // Real spendable credit facility (bookies/agents): the wallet may go negative
  // down to -creditLimit when funding downline. 0 = no credit (hard floor at 0).
  creditLimit     Decimal     @default(0) @db.Decimal(20, 4)
  // High-water mark of a bookie's profit that has already had admin commission
  // collected. Commission is only charged on increases past this — so player
  // wins never trigger a refund and collection can't double-charge.
  commissionedProfit Decimal  @default(0) @db.Decimal(20, 4)
  // Optional display name — used for bookie/agent accounts (e.g. "Acme Bookmakers").
  fullName        String?

  twoFactorSecret String?
  twoFactorEnabled Boolean    @default(false)
  tokenVersion    Int         @default(0)

  lastLoginAt     DateTime?
  lastLoginIp     String?

  // Admin risk controls (Freeze Controls on the user profile).
  withdrawalsFrozen Boolean   @default(false)  // blocks new withdrawal requests
  flaggedSuspicious Boolean   @default(false)  // review marker for risk/monitoring

  wallet          Wallet?
  bets            Bet[]
  ledgerEntries   LedgerEntry[]
  transactions    Transaction[]
  casinoSessions  CasinoSession[]
  exposures       MarketExposure[]
  refreshTokens   RefreshToken[]
  limits          UserLimits?
  adminLogs       AdminLog[]    @relation("AdminActor")
  rouletteBets    RouletteBet[]
  minesSessions   MinesSession[]
  plinkoBets      PlinkoBet[]
  pumpBets        PumpBet[]
  diceBets        DiceBet[]
  towersSessions  TowersSession[]
  chickenRoadSessions ChickenRoadSession[]

  // VIP tier (nullable — most users have no tier assigned)
  vipLevelId      String?
  vipLevel        VipLevel?   @relation(fields: [vipLevelId], references: [id])
  promoRedemptions PromoRedemption[]
  supportTickets  SupportTicket[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([parentId])
  @@index([role, status])
  @@index([vipLevelId])
}

model UserLimits {
  userId              String   @id
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  minStake            Decimal  @default(100)    @db.Decimal(20, 4)
  maxStake            Decimal  @default(100000) @db.Decimal(20, 4)
  maxMarketExposure   Decimal  @default(1000000) @db.Decimal(20, 4)
  maxDailyLoss        Decimal  @default(500000)  @db.Decimal(20, 4)
  betDelayMs          Int      @default(0) // odds delay enforced before bet matches
  fancyEnabled        Boolean  @default(true)
  casinoEnabled       Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// -------------------------------------------------------------
// Wallet & ledger
// -------------------------------------------------------------

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The three balances. balance is the spendable pool;
  // exposure is the sum of liabilities reserved against open bets;
  // bonus is wallet-bonus credit (subject to wager requirement).
  balance       Decimal  @default(0) @db.Decimal(20, 4)
  exposure      Decimal  @default(0) @db.Decimal(20, 4)
  bonus         Decimal  @default(0) @db.Decimal(20, 4)

  currency      String   @default("INR")
  // version is used for optimistic concurrency in WalletService.
  version       Int      @default(0)

  updatedAt     DateTime @updatedAt
}

enum LedgerKind {
  DEPOSIT
  WITHDRAWAL
  BET_PLACE          // exposure increased; balance untouched in exchange model
  BET_SETTLE_WIN
  BET_SETTLE_LOSS
  BET_VOID
  BET_CANCEL
  CASINO_BET
  CASINO_WIN
  CASINO_REFUND
  ADMIN_CREDIT       // manual credit by admin
  ADMIN_DEBIT
  BONUS_GRANT
  BONUS_FORFEIT
  COMMISSION_PAYOUT  // agent commission payout
  BOOKIE_RECHARGE    // admin adds (+) or deducts (-) a bookie's wallet
  BOOKIE_TO_USER     // bookie funds a downline user  (-bookie / +user legs)
  USER_TO_BOOKIE     // bookie reclaims from a user    (-user / +bookie legs)
  ROLLBACK
}

// Append-only ledger. Every wallet mutation MUST land here in the same tx
// that updates Wallet.balance/exposure — that is the invariant the engine
// enforces (see WalletService.applyLedger).
model LedgerEntry {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  kind            LedgerKind
  // Signed delta applied to balance. Use 0 if the entry only affects exposure.
  amount          Decimal     @db.Decimal(20, 4)
  // Signed delta applied to exposure. Positive locks money, negative releases.
  exposureDelta   Decimal     @default(0) @db.Decimal(20, 4)
  balanceAfter    Decimal     @db.Decimal(20, 4)
  exposureAfter   Decimal     @db.Decimal(20, 4)
  refType         String?     // "bet", "transaction", "casino_session", etc.
  refId           String?
  note            String?
  createdAt       DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([refType, refId])
  @@index([kind, createdAt])
}

enum TransactionKind {
  DEPOSIT
  WITHDRAWAL
}

enum TransactionMethod {
  UPI
  BANK_TRANSFER
  CRYPTO
  CARD
  CASH
  ADMIN
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

model Transaction {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  kind          TransactionKind
  method        TransactionMethod
  status        TransactionStatus   @default(PENDING)
  amount        Decimal             @db.Decimal(20, 4)
  reference     String?  // UTR / txn hash / bank ref
  notes         String?
  // Operator approval audit
  reviewedById  String?
  reviewedAt    DateTime?
  // For deposits: details of the source (UPI ID, account, wallet addr)
  payload       Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// -------------------------------------------------------------
// Sports — competitions, matches, markets, runners, bets
// -------------------------------------------------------------

model Sport {
  id        String     @id @default(cuid())
  key       String     @unique  // "cricket", "football", ...
  name      String
  iconUrl   String?
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  competitions Competition[]
  matches      Match[]
}

model Competition {
  id        String   @id @default(cuid())
  sportId   String
  sport     Sport    @relation(fields: [sportId], references: [id])
  name      String
  externalId String? @unique  // map to provider ID
  countryCode String?
  startDate DateTime?
  endDate   DateTime?
  matches   Match[]

  @@index([sportId])
}

enum MatchStatus {
  UPCOMING
  LIVE
  ENDED
  ABANDONED
  CANCELLED
  SETTLED
}

model Match {
  id            String        @id @default(cuid())
  sportId       String
  sport         Sport         @relation(fields: [sportId], references: [id])
  competitionId String?
  competition   Competition?  @relation(fields: [competitionId], references: [id])
  name          String
  homeTeam      String
  awayTeam      String
  startTime     DateTime
  status        MatchStatus   @default(UPCOMING)
  externalId    String?       @unique // provider match id
  inplay        Boolean       @default(false)
  result        Json?         // settled result payload
  markets       Market[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([sportId, startTime])
  @@index([status, startTime])
}

enum MarketType {
  MATCH_ODDS
  BOOKMAKER
  PREMIUM_BOOKMAKER
  FANCY
  SESSION
  OVER_RUNS
  PLAYER_RUNS
  TEAM_TOTAL
  FALL_OF_WICKET
  BOUNDARIES
  PARTNERSHIP
  TIED_MATCH
  TOSS
  FIRST_INNINGS
}

enum MarketStatus {
  OPEN
  SUSPENDED
  CLOSED
  SETTLED
  VOID
}

model Market {
  id            String          @id @default(cuid())
  matchId       String
  match         Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type          MarketType
  name          String
  status        MarketStatus    @default(OPEN)
  minStake      Decimal         @default(100)    @db.Decimal(20, 4)
  maxStake      Decimal         @default(100000) @db.Decimal(20, 4)
  // For fancy markets: target value the user predicts over/under
  fancyTarget   Int?
  externalId    String?         // provider market id
  // Manual odds override: when true, the admin-set odds win over provider feed.
  manualMode    Boolean         @default(false)
  // Snapshot of result for settled markets (winning runner id, fancy actual value, etc.)
  result        Json?

  runners       Runner[]
  bets          Bet[]
  exposures     MarketExposure[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([matchId, type])
  @@index([status])
}

model Runner {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  name        String   // "Mumbai Indians", "Yes", "No", "1", "Tie", ...
  sortOrder   Int      @default(0)
  externalId  String?

  // Latest known odds (also pushed to Redis pub/sub for live updates).
  // Stored as JSON arrays of best 3 levels for back & lay.
  backPrices  Json?
  layPrices   Json?

  bets        Bet[]

  @@index([marketId])
}

enum BetSide {
  BACK
  LAY
}

enum BetStatus {
  OPEN          // bet accepted but match not settled yet
  MATCHED       // (reserved — for true exchange order book later)
  SETTLED_WON
  SETTLED_LOST
  VOID
  CANCELLED
}

model Bet {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  marketId        String
  market          Market     @relation(fields: [marketId], references: [id])
  runnerId        String
  runner          Runner     @relation(fields: [runnerId], references: [id])
  side            BetSide
  odds            Decimal    @db.Decimal(10, 4)
  stake           Decimal    @db.Decimal(20, 4)
  // For fancy markets — the runs/value the user is predicting.
  fancyValue      Int?
  // Potential profit if bet wins (excluding stake).
  potentialProfit Decimal    @db.Decimal(20, 4)
  // Liability locked: the amount the user could lose. Equal to stake on a
  // back bet; equal to stake * (odds - 1) on a lay bet.
  liability       Decimal    @db.Decimal(20, 4)
  status          BetStatus  @default(OPEN)
  // Snapshotted at place time — used in agent commission rollups.
  parentChain     Json?      // [{userId, role, partnershipBps}, ...]
  placedFromIp    String?
  settledAt       DateTime?
  voidReason      String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId, createdAt])
  @@index([marketId, status])
  @@index([status, createdAt])
}

// Per-(user, market) exposure cache, refreshed by ExposureService.
// Drives sticky betslip "potential loss/profit by outcome" displays
// without re-aggregating bets every tick.
model MarketExposure {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId     String
  market       Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  // JSON: { runnerId -> netPL_if_this_runner_wins }
  runnerPL     Json
  // Worst-case loss across runners = the amount we hold in Wallet.exposure for this market.
  worstCase    Decimal  @db.Decimal(20, 4)
  updatedAt    DateTime @updatedAt

  @@unique([userId, marketId])
  @@index([marketId])
}

// -------------------------------------------------------------
// Casino
// -------------------------------------------------------------

model CasinoProvider {
  id        String   @id @default(cuid())
  key       String   @unique  // "evolution", "pragmatic_play", ...
  name      String
  isActive  Boolean  @default(true)
  logoUrl   String?
  games     CasinoGame[]
}

enum CasinoCategory {
  LIVE
  SLOT
  CRASH
  TABLE
  LOTTERY
  VIRTUAL
}

model CasinoGame {
  id          String         @id @default(cuid())
  providerId  String
  provider    CasinoProvider @relation(fields: [providerId], references: [id])
  externalId  String         // provider's game id
  name        String
  category    CasinoCategory
  thumbnail   String?
  isLive      Boolean        @default(false)
  rtp         Decimal?       @db.Decimal(5, 2)
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  sessions    CasinoSession[]

  @@unique([providerId, externalId])
  @@index([category, isActive])
}

model CasinoSession {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  gameId        String
  game          CasinoGame      @relation(fields: [gameId], references: [id])
  // Seamless-transfer token issued to the provider for wallet callbacks.
  providerToken String          @unique
  openedAt      DateTime        @default(now())
  closedAt      DateTime?
  transactions  CasinoTransaction[]
}

enum CasinoTxKind {
  BET
  WIN
  REFUND
  ROLLBACK
}

model CasinoTransaction {
  id           String         @id @default(cuid())
  sessionId    String
  session      CasinoSession  @relation(fields: [sessionId], references: [id])
  externalRef  String
  kind         CasinoTxKind
  amount       Decimal        @db.Decimal(20, 4)
  // Provider round id — used to idempotently dedupe replayed callbacks.
  roundId      String?
  createdAt    DateTime       @default(now())

  @@unique([sessionId, externalRef, kind])
  @@index([roundId])
}

// -------------------------------------------------------------
// Roulette — In-house European roulette (0-36)
// -------------------------------------------------------------

enum RouletteRoundStatus {
  BETTING     // accepting bets
  SPINNING    // ball is rolling, no new bets
  SETTLED     // result announced, payouts complete
}

model RouletteRound {
  id             String              @id @default(cuid())
  roundNumber    Int                 @unique @default(autoincrement())
  status         RouletteRoundStatus @default(BETTING)
  serverSeed     String              // 32-byte hex
  serverSeedHash String              // sha256(serverSeed) — published before round
  winningNumber  Int?                // 0..36, set when settled
  winningColor   String?             // "red" | "black" | "green"
  startedAt      DateTime            @default(now())
  spinAt         DateTime?
  settledAt      DateTime?

  bets RouletteBet[]

  @@index([status, startedAt])
}

model RouletteBet {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  roundId     String
  round       RouletteRound @relation(fields: [roundId], references: [id])
  betType     String        // "number" | "red" | "black" | "odd" | "even" | "high" | "low" | "dozen1" | "dozen2" | "dozen3" | "col1" | "col2" | "col3"
  betValue    String?       // for "number": "0".."36"; otherwise null
  amount      Decimal       @db.Decimal(20, 4)
  payout      Decimal       @default(0) @db.Decimal(20, 4)
  isWin       Boolean       @default(false)
  createdAt   DateTime      @default(now())
  settledAt   DateTime?

  @@index([roundId])
  @@index([userId, createdAt])
}

// -------------------------------------------------------------
// Mines — Provably fair 5x5 grid game
// -------------------------------------------------------------

enum MinesStatus {
  IN_PROGRESS
  CASHED_OUT
  BUSTED
}

model MinesSession {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  betAmount      Decimal     @db.Decimal(20, 4)
  minesCount     Int         @default(3)
  
  // Provably Fair
  serverSeed     String      
  serverSeedHash String      
  clientSeed     String      
  nonce          Int         
  
  // State
  status         MinesStatus @default(IN_PROGRESS)
  multiplier     Decimal     @default(1.00) @db.Decimal(10, 4)
  payout         Decimal     @default(0) @db.Decimal(20, 4)
  
  // The actual mine positions: array of integers 0..24
  minePositions  Json?
  
  // The tiles clicked so far
  clickedTiles   Json?       
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  settledAt      DateTime?

  @@index([userId, status])
  @@index([status, createdAt])
}

// -------------------------------------------------------------
// Operator — API keys, settings, logs, announcements
// -------------------------------------------------------------

enum ApiKeyCategory {
  SPORTS
  CASINO
  CRASH
  SLOTS
  VIRTUAL
  PAYMENT
}

// Admin-configurable provider credentials. Secrets are AES-GCM encrypted
// at rest by ApiKeysService — never stored or returned in plaintext.
model ApiKey {
  id            String         @id @default(cuid())
  providerKey   String         @unique  // matches API_KEY_PROVIDERS[].key
  label         String
  category      ApiKeyCategory
  enabled       Boolean        @default(true)
  // Encrypted JSON blob of credential fields.
  ciphertext    String
  iv            String
  authTag       String
  // Last-4 hint per field (e.g. {"api_key": "…a249"}) for UI display.
  masked        Json?
  notes         String?
  lastUsedAt    DateTime?
  updatedById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Setting {
  key       String   @id  // e.g. "platform.maintenance", "announcement.text"
  value     Json
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  text        String
  level       String   @default("info") // info | warn | promo
  active      Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
}

model AdminLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("AdminActor", fields: [actorId], references: [id])
  action      String   // "user.suspend", "market.suspend", "wallet.credit", ...
  targetType  String?
  targetId    String?
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model PlinkoBet {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  betAmount      Decimal  @db.Decimal(20, 4)
  rows           Int
  riskLevel      String   // "low" | "medium" | "high"
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int
  path           Json     // number[] — 0=left, 1=right per row
  slot           Int      // final slot 0..rows
  multiplier     Decimal  @db.Decimal(10, 4)
  payout         Decimal  @db.Decimal(20, 4)
  profit         Decimal  @db.Decimal(20, 4)
  rtpAtPlay      Decimal? @db.Decimal(5, 2)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// -------------------------------------------------------------
// Pump — Single-player provably fair balloon game (Stake-style)
// -------------------------------------------------------------

enum PumpDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
  INSANE
}

enum PumpStatus {
  ACTIVE   // bet placed, balloon ready to pump
  CASHED   // player cashed out — win
  POPPED   // balloon popped — loss
}

model PumpBet {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])

  betAmount       Decimal        @db.Decimal(20, 4)
  difficulty      PumpDifficulty @default(EASY)

  serverSeed      String         // revealed when session ends
  serverSeedHash  String         // published immediately
  clientSeed      String         @default("")
  nonce           Int            @default(0)

  popPump         Int            // 1-indexed: which pump pops the balloon (pre-determined)
  pumpsCount     Int             @default(0)
  currentMult     Decimal        @default(1) @db.Decimal(10, 4)

  status          PumpStatus     @default(ACTIVE)
  payout          Decimal        @default(0) @db.Decimal(20, 4)
  isWin           Boolean        @default(false)

  createdAt       DateTime       @default(now())
  settledAt       DateTime?

  @@index([userId, createdAt])
  @@index([status])
}

// -------------------------------------------------------------
// Dice — Provably fair Roll Under / Over / Between / Outside
// -------------------------------------------------------------

enum DiceMode {
  ROLL_UNDER
  ROLL_OVER
  ROLL_BETWEEN
  ROLL_OUTSIDE
}

model DiceBet {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  betAmount       Decimal   @db.Decimal(20, 4)
  mode            DiceMode
  // Primary target for ROLL_UNDER / ROLL_OVER
  target          Decimal   @db.Decimal(10, 2)
  // Range targets for ROLL_BETWEEN / ROLL_OUTSIDE
  minTarget       Decimal?  @db.Decimal(10, 2)
  maxTarget       Decimal?  @db.Decimal(10, 2)

  winChance       Decimal   @db.Decimal(10, 4)  // 0.01 – 98.99
  multiplier      Decimal   @db.Decimal(10, 4)  // 99 / winChance

  roll            Decimal   @db.Decimal(10, 2)  // 0.00 – 99.99
  won             Boolean

  payout          Decimal   @db.Decimal(20, 4)
  profit          Decimal   @db.Decimal(20, 4)  // payout - betAmount

  serverSeed      String
  serverSeedHash  String
  clientSeed      String
  nonce           Int

  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─── Towers ──────────────────────────────────────────────────────────────────

enum TowersStatus {
  IN_PROGRESS
  CASHED_OUT
  BUSTED
}

enum TowersDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model TowersSession {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  betAmount      Decimal          @db.Decimal(20, 4)
  difficulty     TowersDifficulty @default(EASY)
  columns        Int
  safeTiles      Int
  bombCount      Int
  levels         Int              @default(8)

  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int

  status         TowersStatus     @default(IN_PROGRESS)
  currentLevel   Int              @default(0)
  multiplier     Decimal          @default(1.00) @db.Decimal(10, 4)
  payout         Decimal          @default(0)    @db.Decimal(20, 4)

  bombPositions  Json             @default("[]")
  pickedCols     Json             @default("[]")

  settledAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── Chicken Road ──────────────────────────────────────────────────────────────

enum ChickenRoadStatus {
  IN_PROGRESS
  CASHED_OUT
  BUSTED
}

enum ChickenRoadDifficulty {
  EASY
  MEDIUM
  HARD
  DAREDEVIL
}

model ChickenRoadSession {
  id             String                @id @default(cuid())
  userId         String
  user           User                  @relation(fields: [userId], references: [id])
  betAmount      Decimal               @db.Decimal(20, 4)
  difficulty     ChickenRoadDifficulty @default(EASY)
  lanes          Int

  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int

  status         ChickenRoadStatus     @default(IN_PROGRESS)
  currentLane    Int                   @default(0)
  multiplier     Decimal               @default(1.00) @db.Decimal(12, 4)
  payout         Decimal               @default(0)     @db.Decimal(20, 4)

  // Boolean per lane: true = a vehicle hits the chicken on that lane.
  deadlyLanes    Json                  @default("[]")

  settledAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// -------------------------------------------------------------
// VIP, promotions & support (engagement)
// -------------------------------------------------------------

model VipLevel {
  id          String   @id @default(cuid())
  name        String
  tier        Int      @unique           // ordering: 0 = lowest tier
  minWagered  Decimal  @default(0) @db.Decimal(20, 4)
  cashbackBps Int      @default(0)        // basis points (500 = 5%)
  bonusAmount Decimal  @default(0) @db.Decimal(20, 4)
  color       String   @default("#fbbf24")
  perks       Json     @default("[]")
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PromoType {
  DEPOSIT_BONUS    // percentage match on deposit
  FREE_CREDIT      // flat wallet credit
  CASHBACK         // percentage cashback
}

model PromoCode {
  id              String            @id @default(cuid())
  code            String            @unique
  type            PromoType         @default(FREE_CREDIT)
  amount          Decimal           @default(0) @db.Decimal(20, 4)  // flat credit (FREE_CREDIT)
  percentage      Int               @default(0)                     // bps (DEPOSIT_BONUS / CASHBACK)
  maxUses         Int?                                              // null = unlimited
  usedCount       Int               @default(0)
  minDeposit      Decimal           @default(0) @db.Decimal(20, 4)
  wagerMultiplier Int               @default(1)
  expiresAt       DateTime?
  active          Boolean           @default(true)
  redemptions     PromoRedemption[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  amount      Decimal   @default(0) @db.Decimal(20, 4)
  createdAt   DateTime  @default(now())

  @@index([promoCodeId])
  @@index([userId])
}

enum SupportStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model SupportTicket {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  subject   String
  status    SupportStatus    @default(OPEN)
  priority  SupportPriority  @default(NORMAL)
  messages  SupportMessage[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@index([userId])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?        // null for system; user id or admin id otherwise
  body      String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId])
}
