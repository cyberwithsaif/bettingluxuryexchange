# ============================================================
# Root environment template — copy to .env for local Docker run.
# Individual apps also have apps/<name>/.env.example
# ============================================================

# --- Postgres ---
POSTGRES_USER=exch
POSTGRES_PASSWORD=exch_dev_password
POSTGRES_DB=exch_platform
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=exch_redis_dev

# --- API ---
API_PORT=4000
DATABASE_URL=postgresql://exch:exch_dev_password@postgres:5432/exch_platform?schema=public
REDIS_URL=redis://:exch_redis_dev@redis:6379

# JWT (rotate in production!)
JWT_ACCESS_SECRET=replace-with-32+char-random-string
JWT_REFRESH_SECRET=replace-with-another-32+char-random
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Bootstrap super admin (created on first run if no users exist)
BOOTSTRAP_SUPERADMIN_USERNAME=admin
BOOTSTRAP_SUPERADMIN_PASSWORD=admin123

# Cricket API (free demo token — completed competitions only)
CRICKET_API_BASE=https://api.cricapi.com
CRICKET_API_TOKEN=ec471071441bb2ac538a0ff901abd249

# --- Web (user-facing) ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_WS_BASE=ws://localhost:4000

# --- Admin ---
ADMIN_PORT=3001
NEXT_PUBLIC_ADMIN_API_BASE=http://localhost:4000
